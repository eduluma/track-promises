    "/admin/promises": {
      "post": {
        "summary": "Create a promise",
        "tags": [
          "promises"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tenantSlug": {
                    "type": "string",
                    "minLength": 1
                  },
                  "timelineSlug": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 5
                  },
                  "description": {
                    "type": "string",
                    "minLength": 20
                  },
                  "category": {
                    "type": "string",
                    "minLength": 1
                  },
                  "jurisdiction": {
                    "type": "string",
                    "minLength": 2
                  },
                  "election": {
                    "type": "string",
                    "minLength": 2
                  },
                  "personParty": {
                    "type": "string",
                    "minLength": 2
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "planned",
                      "in_progress",
                      "fulfilled",
                      "delayed",
                      "disputed"
                    ]
                  }
                },
                "required": [
                  "tenantSlug",
                  "timelineSlug",
                  "title",
                  "description",
                  "category",
                  "jurisdiction",
                  "election",
                  "personParty",
                  "status"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "x-track-promises-user",
            "required": false,
            "description": "Base64-encoded user context forwarded by the web runtime."
          }
        ],
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "promise",
                    "tenantSlug",
                    "timelineSlug"
                  ],
                  "properties": {
                    "promise": {
                      "type": "object",
                      "required": [
                        "id",
                        "tenantId",
                        "timelineSlug",
                        "title",
                        "description",
                        "category",
                        "jurisdiction",
                        "election",
                        "personParty",
                        "status",
                        "createdAt",
                        "updatedAt",
                        "sources",
                        "statusHistory"
                      ],
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "tenantId": {
                          "type": "string"
                        },
                        "timelineSlug": {
                          "type": "string"
                        },
                        "title": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "category": {
                          "type": "string"
                        },
                        "jurisdiction": {
                          "type": "string"
                        },
                        "election": {
                          "type": "string"
                        },
                        "personParty": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "updatedAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "sources": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        },
                        "statusHistory": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": [
                              "previousStatus",
                              "newStatus",
                              "reason",
                              "changedAt"
                            ],
                            "properties": {
                              "previousStatus": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "newStatus": {
                                "type": "string"
                              },
                              "reason": {
                                "type": "string"
                              },
                              "changedAt": {
                                "type": "string",
                                "format": "date-time"
                              }
                            },
                            "additionalProperties": false
                          }
                        }
                      },
                      "additionalProperties": false
                    },
                    "tenantSlug": {
                      "type": "string"
                    },
                    "timelineSlug": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
